# ======================
# DATABASE
# ======================
MONGODB_URI=mongodb://localhost:27017/tendorai
DATABASE_URL_PRODUCTION=mongodb+srv://username:password@cluster.mongodb.net/tendorai

# ======================
# JWT AUTHENTICATION
# ======================
# Generate secrets with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_32_chars_minimum
JWT_REFRESH_SECRET=your_refresh_secret_32_chars_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ======================
# OPENAI API
# ======================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ======================
# EMAIL (Resend)
# ======================
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@tendorai.com
EMAIL_FROM_NAME=TendorAI

# ======================
# APPLICATION
# ======================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# ======================
# FILE UPLOAD
# ======================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,csv,xlsx,xls,doc,docx

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ======================
# SECURITY
# ======================
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here

# ======================
# AWS S3 (Optional - for production)
# ======================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=tendorai-uploads

# ======================
# MONITORING (Optional)
# ======================
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=info

# ======================
# AI PLATFORM API KEYS
# ======================
ANTHROPIC_API_KEY=your_anthropic_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
GEMINI_API_KEY=your_gemini_api_key
GROK_API_KEY=your_grok_api_key

# ======================
# STRIPE
# ======================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Stripe Price IDs (required for checkout)
# These map to the subscription products in your Stripe dashboard
STRIPE_VISIBLE_PRICE_ID=price_xxx
STRIPE_VERIFIED_PRICE_ID=price_xxx

# ======================
# AUTH
# ======================
ADMIN_JWT_SECRET=your_admin_jwt_secret

# ======================
# SCHEMA
# ======================
SCHEMA_ENCRYPT_KEY=your_schema_encrypt_key

# ======================
# CRON
# ======================
ENABLE_CRON=true
